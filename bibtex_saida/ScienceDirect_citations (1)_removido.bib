 issn = {0003-9993},
 journal = {Archives of Physical Medicine and Rehabilitation},
 keywords = {Assistive technology, Autonomous vehicles, Rehabilitation, Universal design},
 number = {8},
 pages = {1536-1544},
 title = {Accessible Autonomous Transportation and Services: Design Considerations From the Perspective of Consumers and Providers},
