 title = {Twenty-Two Years of Minimally Invasive Gynecologic Surgery Fellowship Graduates in the United States and Canada: Geographic Distribution, Accessibility, and Practice Patterns},
 url = {https://www.sciencedirect.com/science/article/pii/S1553465025003073},
