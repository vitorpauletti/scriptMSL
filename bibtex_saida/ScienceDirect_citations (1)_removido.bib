 pages = {106373},
 title = {Geospatial tools in the analyses of land use in the perspective of the accessibility of selected educational services in Poland},
 url = {https://www.sciencedirect.com/science/article/pii/S0264837722004008},
 volume = {122},
 year = {2022}
}

